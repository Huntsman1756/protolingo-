# Local Docker Desktop development template.
# Copy to .env.dev and fill in real secrets locally. Never commit .env.dev.

POSTGRES_DB=freelingo
POSTGRES_USER=freelingo
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATA_PATH=./data

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
SECRET_KEY=CHANGE_ME_SECRET_KEY

CORS_ORIGINS=["http://localhost:48888","http://localhost:3000"]
COOKIE_SECURE=false

EMAIL_ENABLED=false
CONTACT_EMAIL=
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@freelingo.app
SMTP_TLS=true
SMTP_SSL=false
APP_BASE_URL=http://localhost:48888

ALLOW_REGISTRATION=true
FIRST_USER_IS_ADMIN=true
BLOCKED_EMAIL_DOMAINS=[]

LLM_PROVIDER=nan
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-4-5-haiku
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

NAN_API_KEY=
NAN_BASE_URL=https://api.nan.builders/v1
NAN_MODEL=qwen3.6
NAN_EMBEDDING_MODEL=qwen3-embedding
NAN_RERANK_MODEL=rerank
NAN_TTS_MODEL=kokoro
NAN_TTS_VOICE=af_heart
NAN_STT_MODEL=whisper

TTS_PROVIDER=nan
TTS_BASE_URL=http://kokoro:8880
TTS_VOICE=af_heart
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_TTS_SPEED=1.0

STT_PROVIDER=nan
STT_BASE_URL=http://whisper:9000
STT_MODEL=large-v3-turbo
STT_ENGINE=faster_whisper
OPENAI_STT_MODEL=whisper-1

DOCUMENT_OCR_PROVIDER=paddleocr

LOG_LEVEL=INFO
UVICORN_WORKERS=1
AVAILABLE_TARGET_LANGUAGES=["de-DE","en-US","en-GB","es-ES","fr-FR","it-IT","pt-PT"]

STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_TRIAL_DAYS=7
STRIPE_BASE_URL=http://localhost:48888

PRICE_MONTHLY=14.95
PRICE_YEARLY=149.50
TOTAL_PRICE_MONTHLY=19.95
TOTAL_PRICE_YEARLY=199.50

NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_API_URL=http://localhost:8000
